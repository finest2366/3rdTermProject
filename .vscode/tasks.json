{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Qt qmake + make 编译",
            "command": "C:/msys64/ucrt64/bin/qmake6.exe",
            "args": [
                "TankBattle.pro",
                "-spec",
                "win32-g++",
                "CONFIG+=debug",
                "CONFIG+=qml_debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;C:/msys64/ucrt64/share/qt6/bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "qmake生成Makefile",
            "dependsOn": []
        },
        {
            "type": "cppbuild",
            "label": "make 构建",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;C:/msys64/ucrt64/share/qt6/bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "执行make构建",
            "dependsOn": [
                "Qt qmake + make 编译"
            ]
        },
        {
            "type": "cppbuild",
            "label": "GCC 直接编译 (单文件)",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-std=c++23",
                "-fdiagnostics-color=always",
                "-g",
                "-IC:/msys64/ucrt64/include/qt6/QtCore",
                "-IC:/msys64/ucrt64/include/qt6/QtGui",
                "-IC:/msys64/ucrt64/include/qt6/QtWidgets",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-LC:/msys64/ucrt64/lib",
                "-lQt6Widgets",
                "-lQt6Gui",
                "-lQt6Core",
                "-lQt6EntryPoint"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "单文件编译+Qt链接 (不含MOC)"
        }
    ]
}
