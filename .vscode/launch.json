{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GDB Debug (CMake Build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\build\\TankBattle.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}\\build",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:MSYS2_UCRT64_ROOT}\\bin;${env:PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${env:MSYS2_UCRT64_ROOT}/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build"
        }
    ]
}
